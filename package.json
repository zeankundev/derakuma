{
  "name": "derakuma",
  "version": "0.6.2",
  "private": false,
  "description": "a Fontobene parser for Typescript",
  "keywords": [
    "fontobene",
    "vectorfont",
    "font",
    "parser"
  ],
  "homepage": "https://github.com/zeankundev/derakuma#readme",
  "bugs": {
    "url": "https://github.com/zeankundev/derakuma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeankundev/derakuma.git"
  },
  "license": "MIT",
  "author": "zeankun <zeanfender11@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/web.min.js",
  "unpkg": "dist/web.min.js",
  "jsdelivr": "dist/web.min.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:node && npm run build:web",
    "build:node": "tsc -p tsconfig.json",
    "build:web": "tsc -p tsconfig.web.json && esbuild dist/web.js --minify --outfile=dist/web.min.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
