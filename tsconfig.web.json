{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],              // browser build needs DOM types (fetch, window, etc.)
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/web.ts"]
}